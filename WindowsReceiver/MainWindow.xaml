<Window x:Class="PhoneShareReceiver.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PhoneShare Receiver"
        Icon="Assets/phoneshare.ico"
        Width="1080" Height="720"
        MinWidth="1000" MinHeight="680"
        Background="{StaticResource PageBg}"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="18">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="330"/>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 左侧：二维码配对 -->
        <Border Grid.Column="0" Style="{StaticResource Card}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="286"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="扫码绑定手机" Style="{StaticResource CardTitle}"/>

                <Border Grid.Row="1"
                        Background="#FAFAFA"
                        BorderBrush="#F0F0F0"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="14"
                        Margin="0,0,0,16">
                    <Image x:Name="QrImage" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,10">
                    <Ellipse x:Name="StatusDot" Width="10" Height="10" Fill="{StaticResource Green}" VerticalAlignment="Center"/>
                    <TextBlock x:Name="StatusText" Text="正在接收" FontWeight="SemiBold" Foreground="{StaticResource Green}" Margin="8,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>

                <Border Grid.Row="3"
                        Background="#FFFFFF"
                        BorderBrush="#E5E7EB"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="12"
                        Margin="0,0,0,12">
                    <StackPanel>
                        <DockPanel LastChildFill="False" Margin="0,0,0,10">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Ellipse Width="8" Height="8" Fill="#16A34A" VerticalAlignment="Center" Margin="0,0,7,0"/>
                                <TextBlock Text="已配对手机"
                                           Foreground="{StaticResource TextMain}"
                                           FontSize="13.5"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                                <TextBlock x:Name="PairedPhoneCountText"
                                           Text="0 台"
                                           Foreground="{StaticResource TextSub}"
                                           FontSize="12"
                                           Margin="8,0,0,0"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <Button x:Name="ClearPairedPhonesButton"
                                    DockPanel.Dock="Right"
                                    Content="清空"
                                    Click="ClearPairedPhones_Click"
                                    Width="52"
                                    Height="26"
                                    Padding="0"
                                    FontSize="12"
                                    Margin="8,0,0,0"/>
                        </DockPanel>

                        <Border x:Name="EmptyPhonesBox"
                                Background="#F9FAFB"
                                BorderBrush="#E5E7EB"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="12"
                                Margin="0,0,0,0">
                            <StackPanel>
                                <TextBlock Text="暂无已配对手机"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextMain}"
                                           Margin="0,0,0,4"/>
                                <TextBlock Text="请先使用手机扫描二维码完成绑定"
                                           FontSize="12"
                                           Foreground="{StaticResource TextSub}"
                                           TextWrapping="Wrap"
                                           LineHeight="18"/>
                            </StackPanel>
                        </Border>

                        <ScrollViewer MaxHeight="138" VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="PairedPhonesPanel"/>
                        </ScrollViewer>
                    </StackPanel>
                </Border>

                <Border Grid.Row="4" Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="手机连接地址" Foreground="{StaticResource TextSub}" FontSize="12" Margin="0,0,0,5"/>
                        <TextBlock x:Name="UrlText" TextWrapping="Wrap" FontSize="12.5" Foreground="{StaticResource TextMain}" LineHeight="19"/>
                    </StackPanel>
                </Border>

                <UniformGrid Grid.Row="5" Columns="2" Margin="0,0,0,14">
                    <Button Content="刷新二维码" Click="RefreshQr_Click" Margin="0,0,7,0"/>
                    <Button Content="复制配对" Click="CopyPairing_Click" Margin="7,0,0,0"/>
                </UniformGrid>

                <TextBlock Grid.Row="6"
                           Text="首次使用：手机端打开 App 扫码绑定。之后可直接从相册或文件管理器分享文件到电脑。"
                           Foreground="{StaticResource TextSub}"
                           TextWrapping="Wrap"
                           FontSize="12.5"
                           LineHeight="20"
                           VerticalAlignment="Bottom"/>
            </Grid>
        </Border>

        <!-- 右侧：设置 + 日志 -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="14"/>
                <RowDefinition Height="48"/>
                <RowDefinition Height="14"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 设置卡片 -->
            <Border Grid.Row="0" Style="{StaticResource Card}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="接收端设置" Style="{StaticResource CardTitle}"/>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="86"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="118"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="44"/>
                            <RowDefinition Height="44"/>
                            <RowDefinition Height="44"/>
                            <RowDefinition Height="44"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="电脑显示" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="DeviceNameBox" Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="接收文件" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="FolderBox" Grid.Row="1" Grid.Column="1" Margin="0,5,10,5"/>
                        <Button Grid.Row="1" Grid.Column="2" Content="选择目录" Click="ChooseFolder_Click" Margin="0,5,0,5"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="监听端口" Style="{StaticResource FieldLabel}"/>
                        <Grid Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="PortBox" Grid.Column="0"/>
                            <TextBlock Grid.Column="1" Text="建议保持默认，除非端口被占用" Foreground="{StaticResource TextSub}" FontSize="12" VerticalAlignment="Center" Margin="12,0,0,0"/>
                        </Grid>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="启动项" Style="{StaticResource FieldLabel}"/>
                        <CheckBox x:Name="AutoStartCheck" Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" Content="开机自动启动" VerticalAlignment="Center" Checked="AutoStartCheck_Changed" Unchecked="AutoStartCheck_Changed"/>
                    </Grid>
                </Grid>
            </Border>

            <!-- 提示条 -->
            <Border Grid.Row="2" Background="{StaticResource WarnBg}" CornerRadius="12" Padding="14,0">
                <DockPanel LastChildFill="True">
                    <TextBlock Text="提示" FontWeight="SemiBold" Foreground="{StaticResource WarnText}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <TextBlock Text="手机和电脑需处于同一局域网；如果电脑开启 VPN/TUN，请允许局域网访问。首次防火墙弹窗请选择“专用网络”。"
                               Foreground="{StaticResource WarnText}"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>
                </DockPanel>
            </Border>

            <!-- 日志卡片 -->
            <Border Grid.Row="4" Style="{StaticResource Card}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <DockPanel Grid.Row="0" LastChildFill="True" Margin="0,0,0,12">
                        <TextBlock Text="接收日志" Style="{StaticResource CardTitle}" Margin="0"/>
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button x:Name="SaveRestartButton" Content="保存并重启" Style="{StaticResource PrimaryButton}" Click="SaveRestart_Click"/>
                            <Button x:Name="StartStopButton" Content="停止服务" Click="StartStop_Click"/>
                            <Button Content="重置 Token" Click="ResetToken_Click"/>
                            <Button Content="打开文件夹" Click="OpenFolder_Click" Margin="0"/>
                        </StackPanel>
                    </DockPanel>

                    <TextBlock Grid.Row="1" Text="接收成功后会自动保存到上方目录，并在托盘显示提醒。托盘右键菜单可用于打开主窗口、打开文件夹或退出程序。"
                               Foreground="{StaticResource TextSub}" FontSize="12.5" Margin="0,0,0,12"/>

                    <Border Grid.Row="2" Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="12" Padding="12">
                        <TextBox x:Name="LogBox"
                                 Style="{x:Null}"
                                 Background="#F9FAFB"
                                 Foreground="#374151"
                                 BorderThickness="0"
                                 FontFamily="Consolas"
                                 FontSize="13"
                                 IsReadOnly="True"
                                 TextWrapping="NoWrap"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 VerticalAlignment="Stretch"
                                 HorizontalAlignment="Stretch"
                                 VerticalContentAlignment="Top"
                                 Padding="0"/>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
